<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron: V8 JavaScript engine uses JIT compilation. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for Electron: some internal operations need unsigned executable memory. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for sidecar: Python sidecar listens for HTTP connections on localhost. -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- Required for outbound connections: LLM API calls, update checks, etc. -->
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>