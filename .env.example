# XReadAgent — local environment variables.
#
# Copy to ``.env.local`` (gitignored) and fill in the keys you actually use.
# The CLI reads ``.env.local`` from (a) the workspace root or (b) the current
# working directory; values already set in the real environment always win.
#
# You only need one provider's key — the one matching the ``--model`` prefix
# you pass to ``xreadagent ingest``/``query``.

# OpenAI / OpenAI-compatible endpoints (vLLM, LM Studio, …).
# Example model: ``openai:gpt-4o``.
OPENAI_API_KEY=

# Anthropic (Claude family).
# Example model: ``anthropic:claude-sonnet-4-6``.
ANTHROPIC_API_KEY=

# Google Gemini.
# Example model: ``google_genai:gemini-2.5-pro``.
GOOGLE_API_KEY=

# Ollama needs no key for local models.
# Example model: ``ollama:llama3.1:70b``.

# --- Optional ---------------------------------------------------------------

# LangSmith tracing (off by default; opt-in only).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=xreadagent

# Force the in-process stub planner instead of any real LLM (used by tests).
# XREADAGENT_STUB_PLANNER=1
